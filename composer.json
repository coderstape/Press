{
    "name": "coderstape/press",
    "description": "An elegant markdown blog package for the Laravel Framework.",
    "keywords": [
        "laravel",
        "blog",
        "markdown"
    ],
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "erusev/parsedown": "^1.7",
        "illuminate/support": "^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "coderstape\\Press\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "coderstape\\Press\\Tests\\": "tests/",
            "coderstape\\Press\\Database\\Factories\\": "database/factories/"
        }
    },
    "suggest": {
        "league/commonmark": "Required only by press:parser-diff, which compares Parsedown output against it. Laravel already requires this, so it is normally present."
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Victor Gonzalez",
            "email": "victor@coderstape.com"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "coderstape\\Press\\PressBaseServiceProvider"
            ],
            "aliases": {
                "Press": "coderstape\\Press\\Facades\\Press"
            }
        }
    }
}
